# autotrainer environment variables.
#
# Copy to `.env` and edit, or export them in your shell / sbatch script.
# None of these are required for local single-device training - they are only
# needed to override defaults or to run distributed (SLURM / multi-GPU).

# ----------------------------------------------------------------------------
# autotrainer-owned knobs
# ----------------------------------------------------------------------------

# Rendezvous port for the distributed process group (torch DDP) and the
# TensorFlow TF_CONFIG worker list. Must be free on the master node.
# Default: a free OS-assigned port for local multi-GPU launches (so two jobs
# on one machine never collide); 29500 under SLURM, where every node must
# agree on the port up front.
# AUTOTRAINER_PORT=29500

# Set by the launcher on every worker process; user code can check it to know
# it is running under autotrainer (vs. a plain `python script.py`).
# Values: "1" when active. Do not set manually.
# AUTOTRAINER_ACTIVE=

# The launch mode the worker is running under. Set by the launcher.
# Values: "single" | "local_multi_gpu" | "slurm". Do not set manually.
# AUTOTRAINER_MODE=

# Process-group collective timeout in SECONDS (passed to
# torch.distributed.init_process_group). Raise it when a long rank-0 phase -
# e.g. fit()'s tuning search - makes the other ranks wait past torch's
# default (~30 min) at the broadcast that follows.
# Default: torch's default timeout.
# AUTOTRAINER_TIMEOUT=7200

# ----------------------------------------------------------------------------
# Distributed rendezvous vars (set by the launcher; read by torch/tf backends)
# ----------------------------------------------------------------------------
# These are the standard torch.distributed env vars. The launcher sets them
# from its detect() results; under SLURM it translates SLURM_PROCID/LOCALID
# into them. You normally never set these yourself.
#
# RANK=0               # global rank across all nodes
# LOCAL_RANK=0         # rank within this node (maps to a GPU)
# WORLD_SIZE=1         # total number of worker processes
# MASTER_ADDR=127.0.0.1 # rendezvous master hostname
# MASTER_PORT=29500     # rendezvous master port

# ----------------------------------------------------------------------------
# GPU visibility
# ----------------------------------------------------------------------------
# Respected by _gpu_count() BEFORE torch is imported, so it affects mode
# detection (single vs. local_multi_gpu). Comma-separated device indices, or
# "-1"/empty to hide all GPUs.
# CUDA_VISIBLE_DEVICES=0,1

# ----------------------------------------------------------------------------
# SLURM variables consumed by autotrainer (set by the scheduler)
# ----------------------------------------------------------------------------
# These are set by SLURM automatically inside an sbatch allocation; you do
# not set them. Documented here so the contract is visible.
#
# SLURM_JOB_ID            # presence triggers "slurm" mode in detect()
# SLURM_NNODES            # number of nodes allocated -> Environment.nnodes
# SLURM_GPUS_ON_NODE      # GPUs per node -> nproc_per_node (preferred)
# SLURM_NTASKS_PER_NODE   # fallback for nproc_per_node when CPU-only
# SLURM_NODEID            # this node's index -> node_rank
# SLURM_PROCID            # global task id -> RANK (translated by launcher)
# SLURM_LOCALID           # local task id -> LOCAL_RANK (translated by launcher)
# SLURM_NODELIST          # node list, expanded via `scontrol show hostnames`
#                         #   to pick the rendezvous master and build TF_CONFIG
# SLURM_CPUS_PER_TASK     # CPU cores per task -> sklearn n_jobs / boosting
#                         #   thread count (never oversubscribe a shared node)

# ----------------------------------------------------------------------------
# TensorFlow-specific
# ----------------------------------------------------------------------------
# Built by tf_backend.scope() from the SLURM nodelist for
# MultiWorkerMirroredStrategy. Set automatically; do not set manually.
# TF_CONFIG=
